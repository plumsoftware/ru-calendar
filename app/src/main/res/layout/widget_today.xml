<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_today_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg"
    android:orientation="vertical"
    android:padding="10dp">

    <TextView
        android:id="@+id/widget_today_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/widget_today_label"
        android:textColor="@color/widget_text_secondary"
        android:textSize="10sp" />

    <TextView
        android:id="@+id/widget_today_day_number"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/widget_accent"
        android:textSize="28sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widget_today_month_year"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/widget_text_secondary"
        android:textSize="11sp" />

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="6dp"
        android:contentDescription="@null"
        android:src="@drawable/widget_divider" />

    <ListView
        android:id="@+id/widget_today_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@android:color/transparent"
        android:dividerHeight="4dp" />

    <TextView
        android:id="@+id/widget_today_more"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:textColor="@color/widget_accent"
        android:textSize="9sp"
        android:visibility="gone" />

</LinearLayout>
